@{
    ViewBag.Title = "Error";
}

<section class="page-hero" style="min-height:60vh;display:flex;align-items:center;">
    <div class="container">
        <div class="page-hero-content" style="text-align:center;max-width:600px;margin:0 auto;">
            <div style="font-size:5rem;color:rgba(255,255,255,0.3);margin-bottom:24px;"><i class="fas fa-exclamation-triangle"></i></div>
            <h1 style="font-size:2.5rem;">Something Went Wrong</h1>
            <p>We encountered an unexpected error. Please try again or contact us if the issue persists.</p>
            <div style="margin-top:32px;display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
                <a href="/" class="btn-primary">Back to Home <i class="fas fa-home"></i></a>
                <a href="/Contact" class="btn-outline-light">Contact Support</a>
            </div>
        </div>
    </div>
</section>
