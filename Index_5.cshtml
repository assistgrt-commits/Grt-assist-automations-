@{
    ViewBag.Title = "Home";
    var services = ViewBag.Services as List<NTSPLSite.Models.ServiceItem> ?? new();
    var portfolio = ViewBag.Portfolio as List<NTSPLSite.Models.PortfolioItem> ?? new();
    var testimonials = ViewBag.Testimonials as List<NTSPLSite.Models.Testimonial> ?? new();
    var stats = ViewBag.Stats as List<NTSPLSite.Models.StatItem> ?? new();
}

<!-- Hero Section -->
<section class="hero">
    <div class="hero-bg">
        <div class="hero-shape hero-shape-1"></div>
        <div class="hero-shape hero-shape-2"></div>
        <div class="hero-shape hero-shape-3"></div>
    </div>
    <div class="container hero-inner">
        <div class="hero-content">
            <span class="hero-badge"><i class="fas fa-star"></i> Trusted by 200+ Enterprises</span>
            <h1 class="hero-title">
                Transforming Ideas Into<br>
                <span class="highlight">Powerful Digital Solutions</span>
            </h1>
            <p class="hero-subtitle">
                18+ years of delivering enterprise-grade software, cybersecurity, AI/ML, and digital transformation solutions for government bodies, enterprises, and growing businesses.
            </p>
            <div class="hero-capabilities">
                <span><i class="fas fa-check-circle"></i> Software & Web Development</span>
                <span><i class="fas fa-check-circle"></i> UI/UX Design Services</span>
                <span><i class="fas fa-check-circle"></i> PKI & Digital Signatures</span>
                <span><i class="fas fa-check-circle"></i> Business Intelligence</span>
                <span><i class="fas fa-check-circle"></i> AI/ML Development</span>
                <span><i class="fas fa-check-circle"></i> Digital Marketing</span>
            </div>
            <div class="hero-actions">
                <a href="/Contact" class="btn-primary">Start a Project <i class="fas fa-arrow-right"></i></a>
                <a href="/Portfolio" class="btn-outline-light">View Our Work <i class="fas fa-external-link-alt"></i></a>
            </div>
        </div>
        <div class="hero-visual">
            <div class="hero-card-grid">
                <div class="hero-card">
                    <div class="hc-icon"><i class="fas fa-globe"></i></div>
                    <span>Web Development</span>
                </div>
                <div class="hero-card">
                    <div class="hc-icon"><i class="fas fa-shield-alt"></i></div>
                    <span>Cybersecurity</span>
                </div>
                <div class="hero-card">
                    <div class="hc-icon"><i class="fas fa-robot"></i></div>
                    <span>AI / ML</span>
                </div>
                <div class="hero-card">
                    <div class="hc-icon"><i class="fas fa-chart-bar"></i></div>
                    <span>Analytics</span>
                </div>
                <div class="hero-card hero-card-center">
                    <div class="hc-icon hc-center-icon"><i class="fas fa-microchip"></i></div>
                    <span>TechSolvePro</span>
                </div>
                <div class="hero-card">
                    <div class="hc-icon"><i class="fas fa-mobile-alt"></i></div>
                    <span>Mobile Apps</span>
                </div>
                <div class="hero-card">
                    <div class="hc-icon"><i class="fas fa-cloud"></i></div>
                    <span>Cloud Hosting</span>
                </div>
                <div class="hero-card">
                    <div class="hc-icon"><i class="fas fa-bullhorn"></i></div>
                    <span>Digital Marketing</span>
                </div>
                <div class="hero-card">
                    <div class="hc-icon"><i class="fas fa-map-marker-alt"></i></div>
                    <span>GPS Tracking</span>
                </div>
            </div>
        </div>
    </div>
    <div class="hero-scroll-indicator">
        <a href="#services"><i class="fas fa-chevron-down"></i></a>
    </div>
</section>

<!-- Stats Section -->
<section class="stats-section">
    <div class="container">
        <div class="stats-grid">
            @foreach (var stat in stats)
            {
                <div class="stat-item">
                    <div class="stat-icon"><i class="fas fa-@stat.Icon"></i></div>
                    <div class="stat-content">
                        <span class="stat-value" data-target="@stat.Value">@stat.Value</span>
                        <span class="stat-label">@stat.Label</span>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Services Section -->
<section class="services-section section" id="services">
    <div class="container">
        <div class="section-header">
            <span class="section-badge">What We Do</span>
            <h2 class="section-title">Comprehensive IT Services</h2>
            <p class="section-subtitle">From concept to deployment, we deliver end-to-end technology solutions that drive measurable business outcomes.</p>
        </div>
        <div class="services-grid">
            @foreach (var svc in services)
            {
                <a href="@svc.Url" class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-@svc.Icon"></i>
                    </div>
                    <h3 class="service-title">@svc.Title</h3>
                    <p class="service-desc">@svc.Description</p>
                    <span class="service-link">Learn More <i class="fas fa-arrow-right"></i></span>
                </a>
            }
        </div>
        <div class="section-cta">
            <a href="/Services" class="btn-primary">Explore All Services <i class="fas fa-arrow-right"></i></a>
        </div>
    </div>
</section>

<!-- Why Choose Us -->
<section class="why-us-section section">
    <div class="container">
        <div class="why-us-grid">
            <div class="why-us-content">
                <span class="section-badge">Why Choose Us</span>
                <h2 class="section-title">Your Trusted Technology Partner Since 2006</h2>
                <p class="why-us-intro">We combine deep technical expertise with a client-first approach to deliver solutions that genuinely transform businesses and government services.</p>
                <div class="why-us-features">
                    <div class="why-feature">
                        <div class="wf-icon"><i class="fas fa-award"></i></div>
                        <div>
                            <h4>ISO Certified & CMMI Level 3</h4>
                            <p>Quality management processes certified under ISO 9001:2015, ISO 20000-1:2018, and ISO 27001:2013 with CMMI Level 3 assessment.</p>
                        </div>
                    </div>
                    <div class="why-feature">
                        <div class="wf-icon"><i class="fas fa-users"></i></div>
                        <div>
                            <h4>Dedicated Expert Teams</h4>
                            <p>50+ technology specialists across software development, security, design, BI, and AI working collaboratively on your success.</p>
                        </div>
                    </div>
                    <div class="why-feature">
                        <div class="wf-icon"><i class="fas fa-sync-alt"></i></div>
                        <div>
                            <h4>Agile & Transparent Process</h4>
                            <p>Sprint-based delivery with continuous client communication, live demos, and full visibility into project progress at every stage.</p>
                        </div>
                    </div>
                    <div class="why-feature">
                        <div class="wf-icon"><i class="fas fa-headset"></i></div>
                        <div>
                            <h4>Post-Deployment Support</h4>
                            <p>24/7 monitoring, SLA-backed maintenance contracts, and dedicated account managers to ensure continuous performance.</p>
                        </div>
                    </div>
                </div>
                <a href="/Contact" class="btn-primary">Let's Collaborate <i class="fas fa-arrow-right"></i></a>
            </div>
            <div class="why-us-visual">
                <div class="achievement-cards">
                    <div class="ach-card ach-card-1">
                        <div class="ach-icon"><i class="fas fa-certificate"></i></div>
                        <span>ISO 9001:2015</span>
                    </div>
                    <div class="ach-card ach-card-2">
                        <div class="ach-icon"><i class="fas fa-shield-alt"></i></div>
                        <span>ISO 27001:2013</span>
                    </div>
                    <div class="ach-card ach-card-3">
                        <div class="ach-icon"><i class="fas fa-star"></i></div>
                        <span>CMMI Level 3</span>
                    </div>
                    <div class="ach-card ach-card-4">
                        <div class="ach-icon"><i class="fas fa-server"></i></div>
                        <span>ISO 20000-1:2018</span>
                    </div>
                    <img src="https://images.pexels.com/photos/3183150/pexels-photo-3183150.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Team working" class="why-bg-image" />
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Portfolio Section -->
<section class="portfolio-section section">
    <div class="container">
        <div class="section-header">
            <span class="section-badge">Our Work</span>
            <h2 class="section-title">Featured Projects</h2>
            <p class="section-subtitle">A selection of solutions we've built for enterprises, government organizations, and growing businesses across industries.</p>
        </div>
        <div class="portfolio-grid">
            @foreach (var proj in portfolio)
            {
                <div class="portfolio-card">
                    <div class="portfolio-image">
                        <img src="@proj.ImageUrl" alt="@proj.Title" loading="lazy" />
                        <div class="portfolio-overlay">
                            <span class="p-category">@proj.Category</span>
                            <span class="p-industry">@proj.Industry</span>
                        </div>
                    </div>
                    <div class="portfolio-info">
                        <h3>@proj.Title</h3>
                        <p>@proj.Description</p>
                        <div class="p-tech"><i class="fas fa-code"></i> @proj.Technology</div>
                    </div>
                </div>
            }
        </div>
        <div class="section-cta">
            <a href="/Portfolio" class="btn-primary">View All Projects <i class="fas fa-arrow-right"></i></a>
        </div>
    </div>
</section>

<!-- Clients Section -->
<section class="clients-section section">
    <div class="container">
        <div class="section-header">
            <span class="section-badge">Our Clients</span>
            <h2 class="section-title">Trusted by Industry Leaders</h2>
            <p class="section-subtitle">We have had the privilege of working with government bodies, PSUs, and leading enterprises across diverse sectors.</p>
        </div>
        <div class="clients-track-wrapper">
            <div class="clients-track">
                @{
                    var clientNames = new[] { "Steel Authority of India", "Mining Corporation", "Port Trust Authority", "State IT Department", "National Aluminium Co.", "Vedanta Resources", "Oil India Ltd.", "NTPC Limited", "IREDA", "NALCO", "Power Grid Corp.", "Coal India Ltd.", "BHEL", "HAL", "GAIL India" };
                    var clientIcons = new[] { "industry", "mountain", "ship", "landmark", "flask", "gem", "oil-can", "bolt", "solar-panel", "hard-hat", "plug", "fire", "cogs", "plane", "fire-alt" };
                    for (int i = 0; i < clientNames.Length; i++)
                    {
                        <div class="client-logo">
                            <i class="fas fa-@clientIcons[i % clientIcons.Length]"></i>
                            <span>@clientNames[i]</span>
                        </div>
                    }
                    for (int i = 0; i < clientNames.Length; i++)
                    {
                        <div class="client-logo" aria-hidden="true">
                            <i class="fas fa-@clientIcons[i % clientIcons.Length]"></i>
                            <span>@clientNames[i]</span>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</section>

<!-- Testimonials Section -->
<section class="testimonials-section section">
    <div class="container">
        <div class="section-header">
            <span class="section-badge">Client Feedback</span>
            <h2 class="section-title">What Our Clients Say</h2>
            <p class="section-subtitle">We measure our success by the satisfaction and growth of the clients we serve.</p>
        </div>
        <div class="testimonials-slider" id="testimonialSlider">
            @foreach (var t in testimonials)
            {
                <div class="testimonial-card">
                    <div class="t-rating">
                        @for (int i = 0; i < t.Rating; i++)
                        {
                            <i class="fas fa-star"></i>
                        }
                    </div>
                    <p class="t-quote">"@t.Quote"</p>
                    <div class="t-author">
                        <div class="t-author-avatar">
                            <i class="fas fa-user-tie"></i>
                        </div>
                        <div>
                            <strong>@t.Author</strong>
                            <span>@t.Designation, @t.Company</span>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="slider-dots" id="sliderDots"></div>
    </div>
</section>

<!-- Technologies Section -->
<section class="technologies-section section">
    <div class="container">
        <div class="section-header">
            <span class="section-badge">Technology Stack</span>
            <h2 class="section-title">Technologies We Master</h2>
            <p class="section-subtitle">We stay current with the latest tools and frameworks to deliver future-proof solutions.</p>
        </div>
        <div class="tech-categories">
            <div class="tech-cat">
                <h4><i class="fas fa-server"></i> Backend</h4>
                <div class="tech-tags">
                    <span>ASP.NET Core</span><span>C#</span><span>.NET 8</span><span>Node.js</span><span>Python</span><span>Java</span>
                </div>
            </div>
            <div class="tech-cat">
                <h4><i class="fas fa-desktop"></i> Frontend</h4>
                <div class="tech-tags">
                    <span>React.js</span><span>Angular</span><span>Vue.js</span><span>TypeScript</span><span>Blazor</span><span>Next.js</span>
                </div>
            </div>
            <div class="tech-cat">
                <h4><i class="fas fa-mobile-alt"></i> Mobile</h4>
                <div class="tech-tags">
                    <span>Flutter</span><span>React Native</span><span>Android (Kotlin)</span><span>iOS (Swift)</span>
                </div>
            </div>
            <div class="tech-cat">
                <h4><i class="fas fa-database"></i> Database</h4>
                <div class="tech-tags">
                    <span>SQL Server</span><span>PostgreSQL</span><span>MySQL</span><span>Oracle</span><span>MongoDB</span><span>Redis</span>
                </div>
            </div>
            <div class="tech-cat">
                <h4><i class="fas fa-cloud"></i> Cloud</h4>
                <div class="tech-tags">
                    <span>Microsoft Azure</span><span>AWS</span><span>Google Cloud</span><span>Docker</span><span>Kubernetes</span>
                </div>
            </div>
            <div class="tech-cat">
                <h4><i class="fas fa-robot"></i> AI / ML</h4>
                <div class="tech-tags">
                    <span>TensorFlow</span><span>PyTorch</span><span>Azure AI</span><span>AWS ML</span><span>OpenAI API</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="cta-section">
    <div class="container cta-inner">
        <div class="cta-content">
            <h2>Ready to Transform Your Business?</h2>
            <p>Tell us about your project and let our experts craft the perfect solution for your needs.</p>
        </div>
        <div class="cta-actions">
            <a href="/Contact" class="btn-primary-large">Start a Project <i class="fas fa-rocket"></i></a>
            <a href="tel:+918260003333" class="btn-outline-large"><i class="fas fa-phone-alt"></i> +91-82600-03333</a>
        </div>
    </div>
</section>
